generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Sale {
  id          String   @id @default(cuid())
  amount      Int
  description String
  date        DateTime @default(now())
}

model Expense {
  id          String   @id @default(cuid())
  amount      Int
  description String
  date        DateTime @default(now())
}

model Client {
  id        String @id @default(cuid())
  name      String
  phone     String?
  totalDebt Int    @default(0)
  debts     Debt[]
}

model Debt {
  id          String   @id @default(cuid())
  clientId    String
  clientName  String
  amount      Int
  direction   String
  description String
  dueDate     DateTime?
  date        DateTime @default(now())
  status      String   @default("active")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Reminder {
  id        String   @id @default(cuid())
  text      String
  eventAt   DateTime
  remindAt  DateTime
  notified  Boolean  @default(false)
  status    String   @default("active")
  createdAt DateTime @default(now())
}
